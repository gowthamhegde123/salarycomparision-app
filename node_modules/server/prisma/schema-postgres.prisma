// PostgreSQL version of the schema
// Copy this to schema.prisma when deploying to production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Salary {
  id              Int      @id @default(autoincrement())
  jobTitle        String
  industry        String
  location        String
  country         String
  experienceLevel String
  baseSalary      Float
  bonus           Float?
  currency        String   @default("INR")
  companySize     String?
  year            Int
  createdAt       DateTime @default(now())
  userId          Int?
  user            User?    @relation(fields: [userId], references: [id])
}

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  password        String
  salaries        Salary[]
  createdAt       DateTime @default(now())
  currentJob      String?
  currentSalary   Float?
  yearsExperience Float?
  currentCompany  String?
}
