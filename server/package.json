{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch index.js",
    "start": "node index.js",
    "build": "prisma generate && prisma db push --accept-data-loss && npm run import-csv",
    "postinstall": "prisma generate",
    "setup": "node setup-database.js",
    "import-csv": "node prisma/import-csv.js",
    "test-db": "node test-db.js",
    "db:reset": "prisma db push --force-reset && npm run import-csv",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.9.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "prisma": "^5.9.1"
  }
}
